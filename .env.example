APP__NAME=Auth Service
APP__VERSION=0.1.0
APP__API_V1_PREFIX=/api/v1
APP__DEBUG=false

POSTGRES__USER=postgres
POSTGRES__PASSWORD=postgres
POSTGRES__HOST=postgres
POSTGRES__PORT=5432
POSTGRES__DB=auth_service
POSTGRES__URL=postgresql+psycopg://postgres:postgres@postgres:5432/auth_service

REDIS__HOST=redis
REDIS__PORT=6379
REDIS__DB=0
REDIS__URL=redis://redis:6379/0
REDIS__USER_CACHE_TTL_SECONDS=300
REDIS__USER_CACHE_PREFIX=auth:user
REDIS__REFRESH_BLACKLIST_PREFIX=auth:blacklist:refresh

JWT__SECRET_KEY=change-me
JWT__ALGORITHM=HS256
JWT__ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT__REFRESH_TOKEN_EXPIRE_DAYS=30

INTERNAL_AUTH__SERVICE_TOKEN=internal-service-token
INTERNAL_AUTH__SERVICE_HEADER=X-Service-Token

PASSWORD_HASH__ALGORITHM=sha256
PASSWORD_HASH__ITERATIONS=100000
PASSWORD_HASH__SALT_SIZE=16
PASSWORD_HASH__DKLEN=32
